# ── Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API. Use the SERVICE ROLE key (server-side only, never ship
# it to the mobile app). It bypasses RLS so this API is the single gatekeeper.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API auth ───────────────────────────────────────────────────────────────
# Shared secret required in the `x-api-key` header on every /api request.
# Generate one: openssl rand -hex 32
API_KEY=change-me-to-a-long-random-string

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8080
# Comma-separated allowed CORS origins, or * for any (fine for this assessment).
CORS_ORIGIN=*
NODE_ENV=development
