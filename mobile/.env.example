# Backend API base URL.
# - Deployed (recommended): your Render URL, e.g. https://taskflow-backend.onrender.com
# - Local dev on a physical phone: use your Mac's LAN IP (e.g. http://192.168.1.50:8080),
#   NOT localhost — localhost points at the phone itself.
EXPO_PUBLIC_API_URL=https://YOUR-RENDER-APP.onrender.com

# Shared secret; must match the backend's API_KEY. Sent as the x-api-key header.
# NOTE: anything with the EXPO_PUBLIC_ prefix is embedded in the app bundle, so
# this is fine for a single-user assessment but is not a real per-user secret.
EXPO_PUBLIC_API_KEY=change-me-to-match-backend
